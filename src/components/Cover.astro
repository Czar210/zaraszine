---
/* Cover — a assinatura do ZarasZine.
   Renderiza a capa procedural (SVG determinístico do título) OU,
   se o post declara `cover` no frontmatter, a arte própria vence. */
import { coverSvg } from '../lib/cover';

interface Props {
  seed: string;        // título do post
  titulo: string;      // texto sobreposto
  cover?: string;      // caminho de arte própria (opcional)
  eager?: boolean;     // prioridade de carregamento (hero)
}
const { seed, titulo, cover, eager = false } = Astro.props;
const { svg, tintaTitulo } = coverSvg(seed);
---

<div class="cover">
  {cover ? (
    <img src={cover} alt="" loading={eager ? 'eager' : 'lazy'} decoding="async" />
  ) : (
    <div class="proc" set:html={svg} />
  )}
  <p class="ct" style={`color:${cover ? 'var(--papel)' : tintaTitulo}`}>{titulo}</p>
</div>

<style>
  .cover {
    position: relative;
    aspect-ratio: 4 / 5;
    overflow: hidden;
    background: var(--cafe);
  }
  .cover :global(svg),
  .cover img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .ct {
    position: absolute;
    left: 16px;
    right: 16px;
    bottom: 14px;
    margin: 0;
    font-family: var(--f-display);
    font-weight: 400;
    font-size: 1.5rem;
    line-height: 1.08;
    transform: rotate(-1.5deg);
    text-wrap: balance;
    text-shadow: 0 1px 8px rgba(26, 16, 11, 0.55);
  }
</style>
