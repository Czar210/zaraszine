---
/* PostCard — a peça da home. Capa limpa em cima; linha de meta embaixo
   com selo de FORMATO + carimbo de idioma + tema. data-* alimentam os
   filtros client-side. */
import Cover from './Cover.astro';
import LangStamp from './LangStamp.astro';
import FormatBadge from './FormatBadge.astro';
import { urlOf, type Post } from '../lib/i18n';

interface Props {
  post: Post;
  temGemeo?: boolean;
}
const { post, temGemeo = false } = Astro.props;
const { titulo, resumo, tags, data, lang, formato, cover } = post.data;
const tema = tags[0];
const stamp = temGemeo ? 'both' : lang;
const dataFmt = data.toLocaleDateString(lang === 'en' ? 'en-US' : 'pt-BR', {
  day: '2-digit', month: 'short', year: 'numeric',
});
---

<article class="card" data-formato={formato} data-tags={tags.join('|')}>
  <a class="hit" href={urlOf(post)} aria-label={titulo}>
    <Cover seed={titulo} titulo={titulo} cover={cover} />
    <div class="meta">
      <FormatBadge formato={formato} lang={lang} />
      <LangStamp lang={stamp} />
      {tema && <span class="tag">{tema}</span>}
    </div>
    <p class="excerpt">{resumo}</p>
    <p class="date"><time datetime={data.toISOString()}>{dataFmt}</time></p>
  </a>
</article>

<style>
  .card {
    border: var(--borda);
    border-radius: var(--raio);
    background: var(--superficie);
    overflow: hidden;
    transition: transform 0.28s var(--ease), box-shadow 0.28s var(--ease);
  }
  .card:hover, .card:focus-within {
    transform: rotate(-1deg) translateY(-5px);
    box-shadow: 0 18px 40px -18px var(--cafe);
  }
  .hit { display: block; color: inherit; text-decoration: none; }
  .meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 8px;
    padding: 16px 16px 4px;
    font-family: var(--f-mono);
    font-size: var(--t-xs);
    color: var(--meta);
    letter-spacing: 0.06em;
  }
  .tag {
    border: 1px solid var(--linha);
    border-radius: 999px;
    padding: 2px 10px;
  }
  .excerpt {
    font-style: italic;
    font-size: var(--t-sm);
    color: var(--texto);
    margin: 0;
    padding: 8px 16px 4px;
    line-height: 1.5;
  }
  .date {
    margin: 0;
    padding: 4px 16px 16px;
    font-family: var(--f-mono);
    font-size: var(--t-xs);
    color: var(--meta);
    font-variant-numeric: tabular-nums;
  }
</style>
