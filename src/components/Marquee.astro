---
/* Marquee — a faixa que corre. Bilíngue de propósito: o blog inteiro
   vive nas duas línguas, e a fita é onde elas se encostam. */
const frase = 'aprender em público ✳ learn in public ✳ escrito à mão, publicado por git ✳ written by hand, published by git ✳ ';
---

<div class="band" aria-hidden="true">
  <div class="band-track">
    <span>{frase}</span><span>{frase}</span>
  </div>
</div>

<style>
  .band {
    border-block: var(--borda);
    overflow: hidden;
    background: var(--superficie);
  }
  .band-track {
    display: flex;
    width: max-content;
    animation: band-slide 34s linear infinite;
  }
  .band span {
    font-family: var(--f-mono);
    font-size: var(--t-sm);
    letter-spacing: 0.26em;
    text-transform: uppercase;
    color: var(--tinta);
    padding: 11px 0;
    white-space: nowrap;
  }
  @keyframes band-slide { to { transform: translateX(-50%); } }
  @media (prefers-reduced-motion: reduce) {
    .band-track { animation: none; }
    .band span { text-overflow: ellipsis; overflow: hidden; }
  }
</style>
