---
/* Marquee — a faixa que corre, no idioma do mundo atual (por prop). */
interface Props {
  frase: string;
}
const { frase } = Astro.props;
const texto = `${frase} ✳ `;
---

<div class="band" aria-hidden="true">
  <div class="band-track">
    <span>{texto.repeat(3)}</span><span>{texto.repeat(3)}</span>
  </div>
</div>

<style>
  .band {
    border-block: var(--borda);
    overflow: hidden;
    background: var(--superficie);
  }
  .band-track {
    display: flex;
    width: max-content;
    animation: band-slide 40s linear infinite;
  }
  .band span {
    font-family: var(--f-mono);
    font-size: var(--t-sm);
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--tinta);
    padding: 11px 0;
    white-space: nowrap;
  }
  @keyframes band-slide { to { transform: translateX(-50%); } }
  @media (prefers-reduced-motion: reduce) {
    .band-track { animation: none; }
    .band span { text-overflow: ellipsis; overflow: hidden; }
    .band span + span { display: none; }
  }
</style>
