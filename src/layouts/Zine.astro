---
/* Zine — layout do formato gráfico. No M2 é um FALLBACK: capa, texto de
   abertura e as páginas empilhadas na vertical. O folheador de spread
   (2 páginas, vira-página) chega no M3, consumindo o mesmo `paginas`. */
import Base from './Base.astro';
import Cover from '../components/Cover.astro';
import LangStamp from '../components/LangStamp.astro';
import FormatBadge from '../components/FormatBadge.astro';
import ZineFlip from '../components/ZineFlip.astro';
import { UI, urlOf, homeOf, blocoUrl, type Post, type Bloco } from '../lib/i18n';

interface Props {
  post: Post;
  gemeo: Post | null;
  bloco: Bloco | null;
}
const { post, gemeo, bloco } = Astro.props;
const { titulo, resumo, tags, data, lang, cover } = post.data;
const paginas = post.data.paginas ?? [];
const t = UI[lang];
const dataFmt = data.toLocaleDateString(lang === 'en' ? 'en-US' : 'pt-BR', {
  day: '2-digit', month: 'long', year: 'numeric',
});
const outroHref = gemeo ? urlOf(gemeo) : homeOf(lang === 'pt' ? 'en' : 'pt');
const outroLabel = gemeo
  ? (lang === 'pt' ? 'ler em inglês' : 'ler em português')
  : t.outroMundo;
---

<Base
  title={`${titulo} · zaraszine`}
  description={resumo}
  lang={lang}
  outroHref={outroHref}
  outroLabel={outroLabel}
>
  <article class="zine">
    <header class="head narrow">
      <a class="volta" href={homeOf(lang)}>{t.volta}</a>
      <div class="selos">
        <FormatBadge formato="zine" lang={lang} />
        {bloco && <a class="bloco-link" href={blocoUrl(bloco.id)}>{t.bloco}: {bloco.data.titulo}</a>}
      </div>
      <h1>{titulo}</h1>
      <p class="resumo">{resumo}</p>
      <div class="meta">
        <LangStamp lang={gemeo ? 'both' : lang} />
        {tags.map((tag) => <span class="tag">{tag}</span>)}
        <i>✳</i>
        <time datetime={data.toISOString()}>{dataFmt}</time>
        {paginas.length > 0 && <><i>✳</i><span>{paginas.length} {t.paginas}</span></>}
      </div>
    </header>

    <div class="capa">
      <Cover seed={titulo} titulo={titulo} cover={cover} eager={true} />
    </div>

    <div class="prose narrow"><slot /></div>

    {paginas.length > 0 && <ZineFlip paginas={paginas} titulo={titulo} lang={lang} />}

    {gemeo && (
      <aside class="gemeo narrow">
        <a href={urlOf(gemeo)}>
          <LangStamp lang={gemeo.data.lang} />
          <span>{outroLabel} — “{gemeo.data.titulo}”</span>
        </a>
      </aside>
    )}
  </article>
</Base>

<style>
  .head { padding-top: 44px; }
  .volta {
    font-family: var(--f-mono);
    font-size: var(--t-xs);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    text-decoration: none;
  }
  .selos { display: flex; flex-wrap: wrap; align-items: center; gap: 10px; margin-top: 16px; }
  .bloco-link {
    font-family: var(--f-mono);
    font-size: var(--t-xs);
    color: var(--meta);
    text-decoration: none;
    border-bottom: 1px dashed var(--linha);
  }
  .bloco-link:hover { color: var(--fogo); border-color: var(--fogo); }
  h1 {
    font-family: var(--f-display);
    font-weight: 400;
    color: var(--tinta);
    font-size: var(--t-3xl);
    line-height: 1.04;
    letter-spacing: -0.015em;
    text-wrap: balance;
    margin: 14px 0 16px;
  }
  .resumo { font-style: italic; color: var(--meta); font-size: var(--t-md); margin: 0 0 22px; max-width: 54ch; }
  .meta {
    display: flex; flex-wrap: wrap; align-items: center; gap: 10px;
    font-family: var(--f-mono); font-size: var(--t-xs); color: var(--meta); letter-spacing: 0.06em;
  }
  .meta i { font-style: normal; color: var(--fogo); }
  .meta .tag { border: 1px solid var(--linha); border-radius: 999px; padding: 2px 10px; }
  .meta time { font-variant-numeric: tabular-nums; }

  .capa {
    position: relative;
    max-width: 860px;
    margin: 40px auto 12px;
    border: var(--borda);
    border-radius: var(--raio);
    overflow: hidden;
  }
  .capa :global(.cover) { aspect-ratio: 16 / 9; }

  .prose { margin-top: 30px; line-height: 1.75; font-size: var(--t-md); }
  .prose :global(p) { margin: 0 0 1.3em; }
  .prose :global(a) { color: var(--fogo); }

  .gemeo { margin-top: 60px; max-width: 720px; margin-inline: auto; padding: 0 28px; }
  .gemeo a {
    display: inline-flex; align-items: center; gap: 12px; text-decoration: none;
    font-family: var(--f-mono); font-size: var(--t-sm); color: var(--texto);
    border: var(--borda); border-radius: var(--raio); padding: 12px 16px;
  }
  .gemeo a:hover { border-color: var(--fogo); }
</style>
