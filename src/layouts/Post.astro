---
/* Post — template de leitura. Hero com a capa, depois o corpo em
   coluna editorial; imagens grandes sangram e ALTERNAM de lado
   (o Z-shape/assimétrico nasce do CSS, sem exigir nada do autor). */
import Base from './Base.astro';
import Cover from '../components/Cover.astro';
import LangStamp from '../components/LangStamp.astro';
import { UI, urlOf, homeOf, type Post } from '../lib/i18n';

interface Props {
  post: Post;
  gemeo: Post | null;
  minutos: number;
}
const { post, gemeo, minutos } = Astro.props;
const { titulo, resumo, tags, data, lang, cover } = post.data;
const t = UI[lang];
const dataFmt = data.toLocaleDateString(lang === 'en' ? 'en-US' : 'pt-BR', {
  day: '2-digit', month: 'long', year: 'numeric',
});
const outroHref = gemeo ? urlOf(gemeo) : homeOf(lang === 'pt' ? 'en' : 'pt');
const outroLabel = gemeo
  ? (lang === 'pt' ? 'ler em inglês' : 'ler em português')
  : t.outroMundo;
---

<Base
  title={`${titulo} · zaraszine`}
  description={resumo}
  lang={lang}
  outroHref={outroHref}
  outroLabel={outroLabel}
>
  <article class="post">
    <header class="head narrow">
      <a class="volta" href={homeOf(lang)}>{t.volta}</a>
      <h1>{titulo}</h1>
      <p class="resumo">{resumo}</p>
      <div class="meta">
        <LangStamp lang={gemeo ? 'both' : lang} />
        {tags.map((tag) => <span class="tag">{tag}</span>)}
        <i>✳</i>
        <time datetime={data.toISOString()}>{dataFmt}</time>
        <i>✳</i>
        <span>{minutos} {t.leitura}</span>
      </div>
    </header>

    <div class="capa">
      <Cover seed={titulo} titulo={titulo} cover={cover} eager={true} />
    </div>

    <div class="prose narrow">
      <slot />
    </div>

    {gemeo && (
      <aside class="gemeo narrow">
        <a href={urlOf(gemeo)}>
          <LangStamp lang={gemeo.data.lang} />
          <span>{outroLabel} — “{gemeo.data.titulo}”</span>
        </a>
      </aside>
    )}
  </article>
</Base>

<style>
  .head { padding-top: 44px; }
  .volta {
    font-family: var(--f-mono);
    font-size: var(--t-xs);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    text-decoration: none;
  }
  h1 {
    font-family: var(--f-display);
    font-weight: 400;
    color: var(--tinta);
    font-size: var(--t-3xl);
    line-height: 1.04;
    letter-spacing: -0.015em;
    text-wrap: balance;
    margin: 18px 0 16px;
  }
  .resumo {
    font-style: italic;
    color: var(--meta);
    font-size: var(--t-md);
    margin: 0 0 22px;
    max-width: 54ch;
  }
  .meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 10px;
    font-family: var(--f-mono);
    font-size: var(--t-xs);
    color: var(--meta);
    letter-spacing: 0.06em;
  }
  .meta i { font-style: normal; color: var(--fogo); }
  .meta .tag { border: 1px solid var(--linha); border-radius: 999px; padding: 2px 10px; }
  .meta time { font-variant-numeric: tabular-nums; }

  .capa {
    max-width: 860px;
    margin: 40px auto;
    border: var(--borda);
    border-radius: var(--raio);
    overflow: hidden;
    aspect-ratio: 16 / 9;
  }
  .capa :global(.cover) { aspect-ratio: 16 / 9; }

  /* corpo editorial */
  .prose { font-size: var(--t-md); line-height: 1.75; }
  .prose :global(p) { margin: 0 0 1.3em; }
  .prose :global(h2) {
    font-family: var(--f-display);
    font-weight: 400;
    color: var(--tinta);
    font-size: var(--t-xl);
    line-height: 1.15;
    margin: 1.8em 0 0.5em;
    letter-spacing: -0.01em;
  }
  .prose :global(h3) {
    font-family: var(--f-display);
    font-weight: 400;
    color: var(--tinta);
    font-size: var(--t-lg);
    margin: 1.5em 0 0.4em;
  }
  .prose :global(blockquote) {
    margin: 1.6em 0;
    padding: 4px 0 4px 22px;
    border-left: 3px solid var(--fogo);
    font-style: italic;
    color: var(--meta);
  }
  .prose :global(code) {
    font-family: var(--f-mono);
    font-size: 0.86em;
    background: var(--superficie);
    border: 1px solid var(--linha);
    border-radius: 4px;
    padding: 1px 6px;
  }
  .prose :global(pre) {
    background: var(--cafe);
    border: var(--borda);
    border-radius: var(--raio);
    padding: 18px 20px;
    overflow-x: auto;
    font-size: var(--t-sm);
  }
  .prose :global(pre code) { background: none; border: none; padding: 0; }
  .prose :global(hr) { border: none; border-top: var(--borda); margin: 2.4em 0; }
  .prose :global(a) { color: var(--fogo); }

  /* imagens sangram e ALTERNAM de lado — o zigzag do corpo */
  .prose :global(img) {
    display: block;
    width: 100%;
    border: var(--borda);
    border-radius: var(--raio);
    margin: 2em 0;
  }
  @media (min-width: 900px) {
    .prose :global(p.fig-r), .prose :global(p.fig-l) { margin: 2em 0; }
    .prose :global(p.fig-r img), .prose :global(p.fig-l img) { width: min(58vw, 620px); margin-block: 0; }
    .prose :global(p.fig-r img) { margin-left: auto; transform: translateX(9%) rotate(1deg); }
    .prose :global(p.fig-l img) { margin-right: auto; transform: translateX(-9%) rotate(-1deg); }
  }

  .gemeo { margin-top: 60px; }
  .gemeo a {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    text-decoration: none;
    font-family: var(--f-mono);
    font-size: var(--t-sm);
    color: var(--texto);
    border: var(--borda);
    border-radius: var(--raio);
    padding: 12px 16px;
  }
  .gemeo a:hover { border-color: var(--fogo); }
</style>
