---
/* Rota das peças PT — /posts/<slug>. Escolhe layout por formato. */
import { render } from 'astro:content';
import PostLayout from '../../layouts/Post.astro';
import ZineLayout from '../../layouts/Zine.astro';
import { postsDoMundo, gemeoDe, blocoDe, slugOf, tempoLeitura } from '../../lib/i18n';

export async function getStaticPaths() {
  const posts = await postsDoMundo('pt');
  return posts.map((post) => ({ params: { slug: slugOf(post) }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const gemeo = await gemeoDe(post);
const bloco = post.data.bloco ? await blocoDe(post.data.bloco) : null;
const minutos = tempoLeitura(post.body ?? '');
---

{post.data.formato === 'zine' ? (
  <ZineLayout post={post} gemeo={gemeo} bloco={bloco}><Content /></ZineLayout>
) : (
  <PostLayout post={post} gemeo={gemeo} bloco={bloco} minutos={minutos}><Content /></PostLayout>
)}
