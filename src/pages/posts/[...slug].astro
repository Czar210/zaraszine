---
/* Rota dos posts PT — /posts/<slug>. */
import { render } from 'astro:content';
import PostLayout from '../../layouts/Post.astro';
import { postsDoMundo, gemeoDe, slugOf, tempoLeitura } from '../../lib/i18n';

export async function getStaticPaths() {
  const posts = await postsDoMundo('pt');
  return posts.map((post) => ({ params: { slug: slugOf(post) }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const gemeo = await gemeoDe(post);
const minutos = tempoLeitura(post.body ?? '');
---

<PostLayout post={post} gemeo={gemeo} minutos={minutos}>
  <Content />
</PostLayout>
